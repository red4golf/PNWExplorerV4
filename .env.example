# Pacific Northwest Historical Explorer - Environment Variables
# Copy this file to .env and update the values for your deployment

# Database Configuration (Required)
DATABASE_URL=postgresql://username:password@hostname:port/database

# Session Security (Required)
SESSION_SECRET=your-random-session-secret-key-here

# Node Environment (Required for production)
NODE_ENV=production

# Audio Generation (Optional - ElevenLabs for future audio features)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Individual PostgreSQL Components (Auto-extracted from DATABASE_URL)
PGHOST=your-postgres-host
PGPORT=5432
PGDATABASE=your-database-name
PGUSER=your-postgres-username
PGPASSWORD=your-postgres-password

# Replit Specific (Auto-provided in Replit environment)
REPL_ID=auto-provided-by-replit
REPLIT_DOMAINS=auto-provided-by-replit
ISSUER_URL=https://replit.com/oidc

# Application Configuration
PORT=5000
FORCE_DATABASE_STORAGE=true